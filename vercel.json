{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/settle",
      "destination": "/api/settle.js"
    },
    {
      "source": "/v/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/|_vercel/|privacy|terms|contact|settle-an-argument|relationship-argument-judge|roommate-dispute-judge|family-argument-judge|funny-argument-generator|og-image.png|header-gavel.png|justice-scales.png|robots.txt|sitemap.xml|gavel-web.svg|gavel.svg|gavel-hit.mp3).*)",
      "destination": "/index.html"
    }
  ]
}

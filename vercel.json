  "version": 2,
  "rewrites": [
    { "source": "/api/settle", "destination": "/api/settle.js" },
    { "source": "/api/verdict/:id", "destination": "/api/settle.js?id=:id" },
    { "source": "/v/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

